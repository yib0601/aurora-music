{
  "name": "aurora-music",
  "version": "0.1.0",
  "description": "Aurora Music - 跨平台优雅音乐播放器",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @aurora/desktop dev",
    "dev:app": "pnpm --filter @aurora/app dev",
    "dev:desktop": "pnpm --filter @aurora/desktop dev",
    "build": "pnpm -r build",
    "build:app": "pnpm --filter @aurora/app build",
    "build:desktop": "pnpm --filter @aurora/desktop build",
    "preview": "pnpm --filter @aurora/app preview",
    "install:all": "pnpm install",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
