{
  "name": "@aurora/desktop",
  "version": "0.1.2",
  "private": true,
  "description": "Aurora Music - 跨平台优雅音乐播放器",
  "author": "Aurora Music <aurora-music@example.com>",
  "homepage": "https://github.com/aurora-music/aurora-music",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"cd ../app && npx vite --host\" \"wait-on http://localhost:5173 && npx tsc -p tsconfig.electron.json && electron .\"",
    "dev:vite": "cd ../app && npx vite --host",
    "dev:electron": "wait-on http://localhost:5173 && npx tsc -p tsconfig.electron.json && electron .",
    "build": "cd ../app && npx vite build && cd ../desktop && rm -rf app-dist && cp -r ../app/dist app-dist && npx tsc -p tsconfig.electron.json && npx electron-builder",
    "build:dir": "cd ../app && npx vite build && cd ../desktop && rm -rf app-dist && cp -r ../app/dist app-dist && npx tsc -p tsconfig.electron.json && npx electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.electron.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "iconv-lite": "^0.6.3",
    "music-metadata": "^10.5.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^24.13.3",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.aurora.music",
    "productName": "Aurora-Music",
    "executableName": "Aurora-Music",
    "directories": {
      "output": "release"
    },
    "artifactName": "Aurora-Music-${version}.${ext}",
    "files": [
      "dist-electron/**/*",
      "app-dist/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "linux": {
      "target": [
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "AudioVideo",
      "icon": "resources/icon.png",
      "maintainer": "Aurora Music <aurora-music@example.com>",
      "desktop": {
        "entry": {
          "Name": "Aurora Music",
          "Comment": "An elegant cross-platform music player",
          "Categories": "AudioVideo;Audio;",
          "Terminal": false,
          "Type": "Application"
        }
      }
    },
    "deb": {
      "afterInstall": "resources/after-install.sh"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "resources/icon.ico"
    }
  }
}
